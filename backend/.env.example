NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://przeswity:przeswity@db:5432/przeswity
# generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-base64
BETTER_AUTH_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000
# Leave empty on localhost — browsers reject Domain=localhost cookies. Set to e.g. ".przeswity.app" in prod.
COOKIE_DOMAIN=
COOKIE_SECURE=false
PUBLIC_API_URL=http://localhost:8080
COLLAB_PATH=/collaboration
# Dev-only quick-login route. MUST be unset (or false) in production. The app will refuse to boot if both NODE_ENV=production and this is true.
ENABLE_DEV_AUTH=true
# Required when ENABLE_DEV_AUTH=true. Used by `db:seed` and the dev sign-in endpoint.
DEV_SEED_PASSWORD=devseed1234
