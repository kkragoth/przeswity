{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client", "node"],
        "baseUrl": ".",
        "paths": { "@/*": ["src/*"] },
        "noEmit": true
    },
    "include": ["src/**/*", "vite.config.ts"],
    "references": []
}
